{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "qwen3.5": {
          "_launch": true,
          "name": "qwen3.5",
        },
      },
      "options": {
